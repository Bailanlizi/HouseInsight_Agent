# 阿里云 DashScope OpenAI 兼容接口
DASHSCOPE_API_KEY=

# 可选：覆盖默认模型（DashScope 兼容模型名，如 qwen3.6-flash）
HOUSEINSIGHT_LLM_MODEL=qwen3.6-flash

# 为 true 时恢复「清洗 ReAct Agent 改表」旧路径（对照用）；生产请保持 false，清洗走确定性 ETL
# HOUSEINSIGHT_LEGACY_AGENT_CLEAN=false

# 为 true 时对 description_raw 抽样做 L3 弱特征（需 API Key）；默认 false
# HOUSEINSIGHT_DESCRIPTION_ENRICH=false
# HOUSEINSIGHT_DESCRIPTION_SAMPLE_N=200

# 分析规划 LLM 请求中列画像最多条数（控 token）
# HOUSEINSIGHT_PLAN_PROFILE_MAX_COLS=48
